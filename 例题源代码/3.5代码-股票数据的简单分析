3.5.1 抓取股票数据
=============================
```python
import urllib.request
import re
import csv
import os

url = 'http://quote.stockstar.com/stock/ranklist_a_3_1_1.html'
headers = {"User-Agent": "Mozilla/5.0 (Windows NT 10.0; WOW64)"}
request = urllib.request.Request(url=url, headers=headers)
response = urllib.request.urlopen(request)
content = response.read().decode('gbk')
print(content)

# 使用原始字符串避免转义警告
pattern = re.compile(r'<tbody[\s\S]*</tbody>')
body = re.findall(pattern, str(content))

if not body:
    print("未找到tbody内容")
    exit()

pattern = re.compile(r'>(.*?)<')
stock_page = re.findall(pattern, body[0])

# 使用列表推导式删除空字符串，更安全
stock_total = [item for item in stock_page if item != '']
stock_last = stock_total[:]  # 其实这里可以直接用 stock_last = stock_total

head = ['代码', '简称', '最新价', '涨跌幅', '涨跌额', '5分钟涨幅']
lst = []

# 注意缩进：for循环内的代码必须缩进
for i in range(0, len(stock_last), 6):
    # 确保不越界，如果最后一组不足6个则跳过（这里简单处理）
    if i + 5 < len(stock_last):
        lst.append([
            stock_last[i], stock_last[i+1], stock_last[i+2],
            stock_last[i+3], stock_last[i+4], stock_last[i+5]
        ])

# 路径使用双反斜杠或原始字符串
os.chdir(r'D:')  # 或者 'D:\\data_mining\\gupiaoshujufenxi'

with open('test.csv', 'a', newline='', encoding='utf-8') as f:
    f_csv = csv.writer(f)
    f_csv.writerow(head)
    f_csv.writerows(lst)  # 直接写入所有行，更简洁
```
