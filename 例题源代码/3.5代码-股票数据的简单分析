3.5.3 各股票的5分钟涨幅柱状图
=============================
import pandas as pd
import matplotlib.pyplot as plt

# 1. 读取数据（使用正确的路径和编码）
file_path = r'D:\test.csv'  # 根据你的实际路径修改
data = pd.read_csv(file_path, encoding='utf-8')

# 2. 设置中文字体（以黑体为例）
plt.rcParams['font.sans-serif'] = ['SimHei']   # 或 ['Microsoft YaHei']
plt.rcParams['axes.unicode_minus'] = False     # 解决负号显示问题

# 3. 准备数据：按每6只股票一组（最后一组可能不足6只）
names = data['简称'].values          # 股票名称列表
changes = data['5分钟涨幅'].values   # 5分钟涨幅列表

groups = []  # 存储每组股票名称
groups_changes = []  # 存储每组涨幅

for i in range(0, len(names), 6):
    group_names = names[i:i+6]
    group_changes = changes[i:i+6]
    groups.append(group_names)
    groups_changes.append(group_changes)

# 4. 为每组绘制条形图（每组合并到一张图）
for idx, (names_group, changes_group) in enumerate(zip(groups, groups_changes)):
    plt.figure()  # 新建一张图
    x = range(len(names_group))
    plt.bar(x, changes_group, width=0.3, label='5分钟涨幅')
    plt.xticks(x, names_group, rotation=45, ha='right')  # 旋转标签避免重叠
    plt.title(f'第{idx+1}张图')
    plt.legend()
    plt.tight_layout()  # 自动调整布局
    plt.show()

